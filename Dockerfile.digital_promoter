# Build Stage (Same as before)
FROM maven:3.9-eclipse-temurin-17 AS build
WORKDIR /app
COPY . .
RUN mvn clean package -DskipTests

# Run Stage
# THE FIX: We swap Alpine Linux for Microsoft's heavy-duty Playwright image
FROM mcr.microsoft.com/playwright/java:v1.41.0-jammy
WORKDIR /app

# Grab the compiled JAR specifically from the digital-promoter folder
COPY --from=build /app/digital-promoter/target/*.jar app.jar
EXPOSE 8084

ENTRYPOINT ["java", "-jar", "app.jar"]